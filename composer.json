{
  "name": "exonet/powerdns-php",
  "type": "library",
  "description": "PowerDNS API PHP Client",
  "keywords": [
    "exonet",
    "powerdns-php",
    "powerdns-api",
    "powerdns"
  ],
  "homepage": "https://github.com/exonet/powerdns-php",
  "license": "MIT",
  "authors": [
    {
      "name": "Exonet",
      "email": "development@exonet.nl",
      "homepage": "https://exonet.nl",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/exonet/powerdns-php/issues",
    "source": "https://github.com/exonet/powerdns-php"
  },
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.2",
    "psr/log": "^1.0|^2.0|^3.0"
  },
  "require-dev": {
    "dms/phpunit-arraysubset-asserts": "^0.5.0",
    "friendsofphp/php-cs-fixer": "^3.95",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^9"
  },
  "autoload": {
    "psr-4": {
      "Exonet\\Powerdns\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Exonet\\Powerdns\\tests\\": "tests"
    }
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    }
  },
  "scripts": {
    "test": "phpunit",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix"
  }
}
